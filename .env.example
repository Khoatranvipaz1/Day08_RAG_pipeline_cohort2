# OpenAI - generation and optional embeddings
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Jina - reranking and embedding fallback
JINA_API_KEY=
JINA_RERANK_MODEL=jina-reranker-v2-base-multilingual
JINA_EMBEDDING_MODEL=jina-embeddings-v3

# Weaviate - optional vector database
USE_WEAVIATE=false
WEAVIATE_URL=
WEAVIATE_API_KEY=

# PageIndex - optional vectorless fallback
PAGEINDEX_API_KEY=
PAGEINDEX_PROJECT_ID=
